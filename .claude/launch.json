{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "ds-website",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "ds-website-cf",
      "runtimeExecutable": "bunx",
      "runtimeArgs": [
        "wrangler",
        "pages",
        "dev",
        ".vercel/output/static",
        "--compatibility-flag=nodejs_compat",
        "--compatibility-date=2025-12-02",
        "--port=8788"
      ],
      "port": 8788
    }
  ]
}
